<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastro Profissional"
            android:textAlignment="center"
            android:textColor="#0F172A"
            android:textSize="30sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtNomeProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:hint="Nome completo"
            android:backgroundTint="#22C55E"/>

        <EditText
            android:id="@+id/edtDataNascimentoProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="DD/MM/AAAA"
            android:backgroundTint="#22C55E"/>

        <Spinner
            android:id="@+id/spinnerSexoProfissional"
            android:background="@drawable/spinner_background"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/spinnerAreaProfissional"
            android:background="@drawable/spinner_background"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtEmailProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:backgroundTint="#22C55E" />

        <EditText
            android:id="@+id/edtCpfProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="CPF"
            android:inputType="number"
            android:backgroundTint="#22C55E" />

        <EditText
            android:id="@+id/edtDocumentoProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="CREF / CRN / CREFITO"
            android:backgroundTint="#22C55E" />

        <EditText
            android:id="@+id/edtSenhaProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Senha"
            android:inputType="textPassword"
            android:backgroundTint="#22C55E" />

        <Button
            android:id="@+id/btnCadastrarProfissional"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#22C55E"
            android:text="Cadastrar"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>