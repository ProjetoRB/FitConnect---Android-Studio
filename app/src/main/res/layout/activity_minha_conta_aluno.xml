<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minha Conta"
            android:textColor="#22C55E"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#1E293B"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:text="Nome" android:textColor="#94A3B8" android:textSize="14sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtNomeAluno" android:text="Carregando..."
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="Data de nascimento" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtDataNascimentoAluno" android:text="--"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="Email" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtEmailAluno" android:text="--"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="CPF" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtCpfAluno" android:text="--"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="Sexo" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtSexoAluno" android:text="--"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="Peso" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtPesoAluno" android:text="--"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="Altura" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtAlturaAluno" android:text="--"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="Tipo de Conta" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtTipoConta" android:text="Aluno"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:text="ID do Usuário" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginTop="20dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <TextView android:id="@+id/txtIdUsuario" android:text="0"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

        </LinearLayout>

        <Button
            android:id="@+id/btnEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#2563EB"
            android:text="Editar Perfil"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#22C55E"
            android:text="Voltar"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>