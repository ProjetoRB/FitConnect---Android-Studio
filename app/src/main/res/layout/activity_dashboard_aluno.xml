<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="viewModel"
            type="com.fitconnect.viewmodel.DashboardViewModel" />
    </data>

    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/drawerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0F172A"
            android:fillViewport="true">

            <LinearLayout
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- TOPBAR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageButton
                        android:id="@+id/btnMenu"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:backgroundTint="#1E293B"
                        android:padding="10dp" />

                    <ImageButton
                        android:id="@+id/btnRefreshAluno"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#1E293B"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_popup_sync" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FitConnect"
                        android:gravity="center"
                        android:textColor="#22C55E"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="48dp"/>
                </LinearLayout>

                <!-- BANNER -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="155dp"
                    android:layout_marginBottom="18dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_banner_overlay"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Sua evolucao comeca com o profissional certo."
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nutricionistas, personal trainers e fisioterapeutas conectados em uma unica plataforma."
                            android:textColor="#CBD5E1"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- CONSULTAS PENDENTES -->
                <Button
                    android:id="@+id/btnOcultarConsultasAluno"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="#22C55E"
                    android:text="Ocultar consultas"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_banner_overlay"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Consultas Pendentes"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:id="@+id/pendingList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSemConsultas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nenhuma consulta pendente."
                            android:textColor="#64748B"
                            android:textSize="14sp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- SECAO PROFISSIONAIS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_banner_overlay"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Qual tipo de servico voce precisa?"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- FILTROS -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <Button
                                android:id="@+id/btnFiltroTodos"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_filter_active"
                                android:text="Todos"
                                android:textColor="#CBD5E1"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <Button
                                android:id="@+id/btnFiltroNutri"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_filter_inactive"
                                android:text="Nutricionista"
                                android:textColor="#CBD5E1"
                                android:textSize="13sp"/>

                            <Button
                                android:id="@+id/btnFiltroPersonal"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_filter_inactive"
                                android:text="Personal Trainer"
                                android:textColor="#CBD5E1"
                                android:textSize="13sp"/>

                            <Button
                                android:id="@+id/btnFiltroFisio"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_filter_inactive"
                                android:text="Fisioterapeuta"
                                android:textColor="#CBD5E1"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </HorizontalScrollView>

                    <!-- PROFISSIONAIS -->
                    <LinearLayout
                        android:id="@+id/profissionaisContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBuscando"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Buscando profissionais..."
                            android:textColor="#64748B"
                            android:textSize="14sp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>
    <!-- MENU LATERAL -->
        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FitConnect"
                android:textColor="#22C55E"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnMinhaConta"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:text="Minha conta"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:id="@+id/btnContato"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:text="Contato"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:id="@+id/btnServicos"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:text="Serviços"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:id="@+id/btnSairAluno"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sair"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>
        </LinearLayout>

    </androidx.drawerlayout.widget.DrawerLayout>

</layout>