<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/drawerLayoutProfissional"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0F172A"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- TOPO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnMenuProfissional"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:backgroundTint="#1E293B"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="48dp"
                        android:gravity="center"
                        android:text="FitConnect"
                        android:textColor="#22C55E"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBoasVindasProfissional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Olá, "
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Gerencie seus alunos e horários"
                    android:textColor="#94A3B8"
                    android:textSize="14sp" />

                <!-- CARDS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_banner_overlay"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total de agendamentos"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_banner_overlay"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quantidade de alunos"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- AGENDAMENTOS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_banner_overlay"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alunos com agendamentos"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Nenhum agendamento encontrado"
                        android:textColor="#94A3B8"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- MENU LATERAL -->
        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FitConnect"
                android:textColor="#22C55E"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Minha conta"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Contato"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Serviços"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Minha Agenda"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

            <Button
                android:id="@+id/btnSairProfissional"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sair"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#CBD5E1"/>

        </LinearLayout>

    </androidx.drawerlayout.widget.DrawerLayout>

</layout>