<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_consulta.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_profissional"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Data e hora -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDataConsulta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00/00/0000"
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvHoraConsulta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#94A3B8"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Badge de status -->
        <TextView
            android:id="@+id/tvStatusConsulta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tag"
            android:text="agendado"
            android:textColor="#052E16"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

    </LinearLayout>

    <!-- Botão cancelar -->
    <Button
        android:id="@+id/btnCancelarConsulta"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="@drawable/bg_button_cancelar"
        android:text="Cancelar consulta"
        android:textColor="#FFFFFF"
        android:textSize="13sp"/>

</LinearLayout>