<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="viewModel"
            type="com.fitconnect.viewmodel.AgendamentoViewModel" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F172A"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TOPBAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btnVoltar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&lt; Voltar"
                    android:textColor="#22C55E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:padding="4dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Agendar consulta"
                    android:textColor="#F1F5F9"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- CARD PROFISSIONAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profissional"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvNomeProfissional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#F1F5F9"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvAreaProfissional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#22C55E"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- CARD HORARIOS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Horarios disponiveis"
                    android:textColor="#F1F5F9"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- ProgressBar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- Placeholder sem horários -->
                <TextView
                    android:id="@+id/tvSemHorarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum horario disponivel."
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:visibility="gone"/>

                <!-- Lista de horários -->
                <LinearLayout
                    android:id="@+id/listaHorarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

            <!-- BOTÃO CONFIRMAR -->
            <Button
                android:id="@+id/btnConfirmar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_green"
                android:text="Confirmar agendamento"
                android:textColor="#052E16"
                android:textSize="15sp"
                android:textStyle="bold"
                android:enabled="false"
                android:alpha="0.5"/>

        </LinearLayout>

    </ScrollView>

</layout>